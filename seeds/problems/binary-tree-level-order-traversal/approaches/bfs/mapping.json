{
  "primitive": "tree",
  "nodesFrom": "nodes",
  "currentNodeVar": "cur_id",
  "nodeStateRules": [
    {
      "state": "current",
      "when": "node_idx == cur_id"
    },
    {
      "state": "visited",
      "when": "status[node_idx] == 2"
    },
    {
      "state": "frontier",
      "when": "status[node_idx] == 1"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "auxMappings": [
    {
      "label": "Queue (this level + next)",
      "primitive": "queue",
      "itemsFrom": "queue",
      "cellStateRules": [
        {
          "state": "visited",
          "when": "idx < head"
        },
        {
          "state": "frontier",
          "when": "true"
        },
        {
          "state": "idle",
          "when": "true"
        }
      ]
    }
  ],
  "readout": {
    "expr": "{len(result)} level(s) collected",
    "when": "phase != 'return'"
  },
  "counters": [
    {
      "name": "nodes visited",
      "onLines": [
        39
      ],
      "when": "true"
    }
  ],
  "phaseRules": [
    {
