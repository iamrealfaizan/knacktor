        5
      ]
    },
    {
      "phase": "loop",
      "lines": [
        6,
        7
      ]
    },
    {
      "phase": "update",
      "lines": [
        8,
        9,
        10,
        11,
        12,
        13,
        14
      ]
    },
    {
      "phase": "move",
      "lines": [
        15,
        16
      ]
    },
    {
