{
  "primitive": "grid",
  "gridFrom": "matrix",
  "cellStateRules": [
    {
      "state": "special",
      "when": "offset != null && top != null && ((r == top && c == left + offset) || (r == bottom - offset && c == left) || (r == bottom && c == right - offset) || (r == top + offset && c == right))"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "readout": {
    "when": "offset != null && phase != 'return'",
    "expr": "ring [{left}..{right}] Â· offset {offset}",
    "relationColor": "special"
  },
  "counters": [
