{
  "primitive": "array",
  "valuesFrom": "s",
  "pointers": [
    {
      "name": "i",
      "var": "i"
    },
    {
      "name": "left",
      "var": "left"
    },
    {
      "name": "right",
      "var": "right"
    }
  ],
  "flags": {
    "windowing": "left != null"
  },
  "cellStateRules": [
    {
      "state": "result",
      "when": "matched && windowing && idx >= left && idx <= right"
    },
    {
      "state": "special",
      "when": "idx == right"
    },
    {
      "state": "compared",
      "when": "idx == left"
    },
    {
      "state": "current",
      "when": "idx == i"
    },
    {
      "state": "dimmed",
      "when": "windowing && (idx < left || idx > right)"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "window": {
    "from": "left",
    "to": "right"
  },
  "auxMappings": [
    {
      "label": "Target counts (p)",
      "primitive": "hashmap",
      "keysFrom": "need",
      "valuesFrom": "need",
      "highlightRules": [
        {
          "state": "result",
          "whenKey": "matched"
        },
        {
          "state": "idle",
          "whenKey": "true"
        }
      ]
    },
    {
      "label": "Window counts",
      "primitive": "hashmap",
      "keysFrom": "window",
      "valuesFrom": "window",
      "highlightRules": [
        {
          "state": "result",
          "whenKey": "matched"
        },
        {
          "state": "special",
          "whenKey": "k == enter"
        },
        {
          "state": "compared",
          "whenKey": "k == leave"
        },
        {
          "state": "idle",
          "whenKey": "true"
        }
      ]
    }
  ],
  "readout": {
    "when": "windowing && phase != 'return'",
    "expr": "window [{left}..{right}] · {matched ? 'ANAGRAM!' : 'no match'}"
  },
  "counters": [
    {
      "name": "windows checked",
      "onLines": [
        23,
        39
      ]
    },
    {
      "name": "anagrams found",
      "onLines": [
        25,
        41
      ]
    }
  ],
  "phaseRules": [
    {
      "phase": "init",
      "lines": [
