{
  "primitive": "tree",
  "nodesFrom": "nodes",
  "currentNodeVar": "cur",
  "nodeStateRules": [
    {
      "state": "current",
      "when": "node_idx == cur"
    },
    {
      "state": "visited",
      "when": "state_by_id[node_idx] == 2"
    },
    {
      "state": "frontier",
      "when": "state_by_id[node_idx] == 1"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "auxMappings": [
    {
      "label": "Queue (node ids)",
      "primitive": "queue",
      "itemsFrom": "queue",
      "cellStateRules": [
        {
          "state": "frontier",
          "when": "true"
        },
        {
          "state": "idle",
          "when": "true"
        }
      ]
    }
  ],
  "readout": {
    "when": "cur != -1",
    "expr": "dequeued node {cur} — {len(queue)} still in queue"
  },
  "counters": [
    {
      "name": "nodes visited",
      "onLines": [
        30
      ],
      "when": "true"
    }
  ],
  "phaseRules": [
    {
