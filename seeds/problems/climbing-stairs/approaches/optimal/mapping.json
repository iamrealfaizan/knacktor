{
  "primitive": "array",
  "valuesFrom": "dp",
  "cellStateRules": [
    {
      "state": "result",
      "when": "idx == n && phase == 'return'"
    },
    {
      "state": "current",
      "when": "idx == i"
    },
    {
      "state": "compared",
      "when": "idx == i - 1 || idx == i - 2"
    },
    {
      "state": "visited",
      "when": "idx < i"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "pointers": [
    {
      "name": "i",
      "var": "i"
    }
  ],
  "ghosts": {
    "track": [
      "i"
    ]
  },
  "readout": {
    "expr": "dp[{i}] = dp[{i - 1}] + dp[{i - 2}] = {dp[i - 1]} + {dp[i - 2]}",
    "relation": "ways to reach step {i}",
    "relationColor": "current",
    "when": "phase == 'loop' || phase == 'update'"
  },
  "counters": [
    {
      "name": "additions",
      "onLines": [
        7
      ],
      "when": "true"
    }
  ],
  "phaseRules": [
    {
      "phase": "init",
      "lines": [
        3,
        4,
        5
      ]
    },
    {
      "phase": "loop",
      "lines": [
        6
      ]
    },
    {
      "phase": "update",
      "lines": [
        7,
        8
      ]
    },
    {
      "phase": "return",
      "lines": [
        9
      ]
    }
  ],
  "keyEvents": [
    {
      "line": 8,
      "label": "dp[n] holds the answer",
      "kind": "result"
    },
    {
      "line": 9,
      "label": "Total ways returned",
      "kind": "return"
    }
  ]
}
