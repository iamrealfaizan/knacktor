{
  "primitive": "array",
  "valuesFrom": "dp",
  "pointers": [
    {
      "name": "i",
      "var": "i"
    }
  ],
  "ghosts": {
    "track": [
      "i"
    ]
  },
  "cellStateRules": [
    {
      "state": "result",
      "when": "idx == n && phase == 'return'"
    },
    {
      "state": "current",
      "when": "idx == i"
    },
    {
      "state": "compared",
      "when": "idx == i - 1 || idx == i - 2"
    },
    {
      "state": "dimmed",
      "when": "idx == 0"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "readout": {
    "when": "i != null && phase != 'return'",
    "expr": "dp[{i}] = dp[{i-1}] + dp[{i-2}] = {dp[i-1]} + {dp[i-2]}"
  },
  "counters": [
    {
      "name": "cells computed",
      "onLines": [
        9
      ],
      "when": "true"
    }
  ],
  "phaseRules": [
    {
      "phase": "init",
      "lines": [
        3,
        4,
        5,
        6,
        7
      ]
    },
    {
      "phase": "loop",
      "lines": [
        8
      ]
    },
    {
      "phase": "update",
      "lines": [
        9
      ]
    },
    {
      "phase": "return",
      "lines": [
        10,
        11
      ]
    }
  ],
  "keyEvents": [
    {
      "line": 9,
      "when": "i == n",
      "label": "Top stair filled",
      "kind": "boundary"
    },
    {
      "line": 11,
      "label": "Return total ways",
      "kind": "return"
    }
  ]
}
