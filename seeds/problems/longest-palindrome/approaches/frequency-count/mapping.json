{
  "primitive": "hashmap",
  "keysFrom": "counts",
  "valuesFrom": "counts",
  "pointers": [],
  "flags": {
    "folding": "key != null"
  },
  "highlightRules": [
    {
      "state": "special",
      "whenKey": "k == key && counts[key] % 2 == 1"
    },
    {
      "state": "result",
      "whenKey": "k == key"
    },
    {
      "state": "current",
      "whenKey": "k == ch && !folding"
    },
    {
      "state": "idle",
      "whenKey": "true"
    }
  ],
  "auxMappings": [
    {
      "label": "Input string",
      "primitive": "array",
      "valuesFrom": "s",
      "pointers": [
        {
          "name": "i",
          "var": "i"
        }
      ],
      "cellStateRules": [
        {
          "state": "current",
          "when": "idx == i"
        },
        {
          "state": "visited",
          "when": "idx < i"
        },
        {
          "state": "idle",
          "when": "true"
        }
      ]
    }
  ],
  "readout": {
    "when": "length != null && phase != 'return'",
    "expr": "pairs collected → length {length}"
  },
