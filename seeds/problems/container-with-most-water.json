    "greedy"
  ],
  "patterns": [
    "two-pointers"
  ],
  "statement": "You are given an integer array height of length n. There are n vertical lines drawn such that the two endpoints of the ith line are (i, 0) and (i, height[i]). Find two lines that together with the x-axis form a container that stores the most water. Return the maximum amount of water the container can store. You may not slant the container.",
  "recommendedApproachId": "two-pointers",
  "supportsCompare": true,
  "supportsCustomInput": true,
  "approaches": [
    {
      "id": "brute-force",
      "name": "Brute Force",
      "kind": "brute",
      "summary": "Try every possible pair of lines and calculate the water area for each pair.",
      "complexity": {
        "time": "O(n^2)",
        "space": "O(1)"
      },
      "primaryPrimitive": "array",
      "auxStructures": [],
      "source": "class Solution(object):\n    def maxArea(self, height):\n        mx = 0\n        n = len(height)\n        for i in range(n):\n            for j in range(i + 1, n):\n                width = j - i\n                h = min(height[i], height[j])\n                area = width * h\n                mx = max(mx, area)\n        return mx",
      "lineExplanations": {
        "1": "Define the Solution class for LeetCode.",
        "2": "Define the maxArea function that takes the height array.",
        "3": "Initialize the maximum area as 0.",
        "4": "Store the length of the height array.",
        "5": "Pick the first line.",
        "6": "Pick the second line after the first line.",
        "7": "Calculate the distance between the two lines.",
        "8": "The container height is limited by the shorter line.",
        "9": "Calculate the water area.",
        "10": "Update the maximum area if this pair gives a larger area.",
        "11": "Return the largest area found."
      },
      "syntaxExplanations": {
        "3": "mx stores the best answer found so far.",
        "5": "range(n) loops from 0 to n - 1.",
        "6": "range(i + 1, n) checks every line to the right of i.",
        "8": "min() returns the smaller of the two heights.",
        "10": "max() keeps the larger value between mx and area."
      },
      "resultSpec": {
        "varName": "mx",
        "label": "BEST AREA",
        "suffix": "· max water",
        "render": "scalar"
      }
    },
    {
      "id": "two-pointers",
      "name": "Two Pointers",
      "kind": "optimal",
      "summary": "Start with the widest container using two pointers. Calculate the area, then move the pointer at the shorter line inward.",
      "complexity": {
        "time": "O(n)",
        "space": "O(1)"
      },
      "primaryPrimitive": "array",
      "auxStructures": [],
      "source": "class Solution(object):\n    def maxArea(self, height):\n        lp = 0\n        rp = len(height) - 1\n        mx = 0\n\n        while lp < rp:\n            width = rp - lp\n            h = min(height[lp], height[rp])\n            area = width * h\n            mx = max(mx, area)\n\n            if height[lp] < height[rp]:\n                lp += 1\n            else:\n                rp -= 1\n\n        return mx",
      "lineExplanations": {
        "1": "Define the Solution class for LeetCode.",
        "2": "Define the maxArea function that receives the height array.",
        "3": "Place the left pointer at the start of the array.",
        "4": "Place the right pointer at the end of the array.",
        "5": "Initialize the maximum area as 0.",
        "7": "Keep checking while the two pointers have not crossed.",
        "8": "The width is the distance between the two pointers.",
        "9": "The usable water height is limited by the shorter line.",
        "10": "Calculate the current container area.",
        "11": "Update the best maximum area found so far.",
        "13": "If the left line is shorter, move the left pointer inward.",
        "14": "Move the left pointer one step right.",
        "15": "Otherwise, move the right pointer inward.",
        "16": "Move the right pointer one step left.",
        "18": "Return the largest area found."
      },
      "syntaxExplanations": {
        "3": "lp stands for left pointer.",
        "4": "rp stands for right pointer. len(height) - 1 gives the last index.",
        "7": "while lp < rp keeps looping while there are two valid lines.",
        "8": "rp - lp gives the horizontal distance between the two lines.",
        "9": "height[lp] accesses the left line height, and height[rp] accesses the right line height.",
        "11": "max(mx, area) keeps the larger value.",
        "13": "The shorter side limits the water, so we move that pointer.",
        "14": "lp += 1 means lp = lp + 1.",
        "16": "rp -= 1 means rp = rp - 1."
      },
      "resultSpec": {
        "varName": "mx",
        "label": "BEST AREA",
        "suffix": "· max water",
        "render": "scalar"
      }
    }
  ],
