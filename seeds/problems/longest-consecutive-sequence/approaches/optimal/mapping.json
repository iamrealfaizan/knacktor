{
  "primitive": "array",
  "valuesFrom": "nums",
  "cellStateRules": [
    {
      "state": "compared",
      "when": "current != null && values[idx] == current + 1"
    },
    {
      "state": "current",
      "when": "current != null && values[idx] == current"
    },
    {
      "state": "special",
      "when": "num != null && values[idx] == num"
    },
    {
      "state": "path",
      "when": "num != null && current != null && values[idx] > num && values[idx] < current"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "readout": {
    "when": "current != null && phase != 'return'",
    "expr": "run from {num}: head {current}, length {current_length}",
    "relation": "best {longest}",
    "relationColor": "result"
  },
  "counters": [
    {
      "name": "walks",
      "onLines": [
        10
      ]
    }
  ],
  "phaseRules": [
    {
      "phase": "init",
      "lines": [
        3,
        4
      ]
    },
    {
      "phase": "loop",
      "lines": [
        5,
        9
      ]
    },
    {
      "phase": "check",
      "lines": [
        6
      ]
    },
    {
      "phase": "update",
      "lines": [
        7,
        8,
        11,
        12
      ]
    },
    {
      "phase": "move",
      "lines": [
        10
      ]
    },
    {
      "phase": "return",
      "lines": [
        13
      ]
    }
  ],
  "keyEvents": [
    {
      "line": 13,
      "label": "Longest run",
      "kind": "return"
    }
  ]
}
