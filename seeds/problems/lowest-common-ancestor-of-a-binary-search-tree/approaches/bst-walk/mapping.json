{
  "primitive": "tree",
  "nodesFrom": "nodes",
  "currentNodeVar": "current",
  "nodeStateRules": [
    {
      "state": "result",
      "when": "node_idx == current && found"
    },
    {
      "state": "current",
      "when": "node_idx == current"
    },
    {
      "state": "visited",
      "when": "state_by_id[node_idx] == 2"
    },
    {
      "state": "frontier",
      "when": "state_by_id[node_idx] == 1"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "readout": {
    "when": "current_val != null && phase != 'return'",
    "expr": "at node {current_val} · comparing p = {p} and q = {q}"
  },
