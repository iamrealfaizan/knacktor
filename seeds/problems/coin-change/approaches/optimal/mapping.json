{
  "primitive": "array",
  "valuesFrom": "dp",
  "cellStateRules": [
    {
      "state": "result",
      "when": "idx == amount && phase == 'return'"
    },
    {
      "state": "current",
      "when": "idx == a"
    },
    {
      "state": "compared",
      "when": "idx == a - coin && coin <= a && (phase == 'check' || phase == 'update')"
    },
    {
      "state": "visited",
      "when": "idx < a"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "pointers": [
    {
      "name": "a",
      "var": "a"
    }
  ],
  "ghosts": {
    "track": [
      "a"
    ]
  },
  "readout": {
    "expr": "coin {coin}: dp[{a - coin}] + 1 = {dp[a - coin] + 1} vs dp[{a}] = {dp[a]}",
    "relation": "solving amount {a}",
    "relationColor": "current",
    "when": "coin <= a && (phase == 'check' || phase == 'update')"
  },
  "counters": [
    {
      "name": "comparisons",
      "onLines": [
        8
      ],
      "when": "true"
    }
  ],
  "phaseRules": [
    {
      "phase": "init",
      "lines": [
        3,
        4
      ]
    },
    {
      "phase": "loop",
      "lines": [
        5,
        6
      ]
    },
    {
      "phase": "check",
      "lines": [
        7,
        8
      ]
    },
    {
      "phase": "update",
      "lines": [
        9
      ]
    },
    {
      "phase": "return",
      "lines": [
        10,
        11,
        13,
        14
      ]
    }
  ],
  "keyEvents": [
    {
      "line": 11,
      "label": "Amount is unreachable",
      "kind": "boundary"
    },
    {
      "line": 13,
      "label": "Answer read from dp[amount]",
      "kind": "result"
    },
    {
      "line": 14,
      "label": "Fewest coins returned",
      "kind": "return"
    }
  ]
}
