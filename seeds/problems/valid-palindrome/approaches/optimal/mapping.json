{
  "primitive": "array",
  "valuesFrom": "s",
  "cellStateRules": [
    {
      "state": "result",
      "when": "phase == 'return'"
    },
    {
      "state": "error",
      "when": "(idx == left || idx == right) && phase == 'done'"
    },
    {
      "state": "compared",
      "when": "(idx == left || idx == right) && phase == 'check'"
    },
    {
      "state": "current",
      "when": "idx == left || idx == right"
    },
    {
      "state": "visited",
      "when": "idx < left || idx > right"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "pointers": [
    {
      "name": "left",
      "var": "left"
    },
    {
      "name": "right",
      "var": "right"
    }
  ],
  "readout": {
    "when": "phase == 'check'",
    "expr": "compare s[{left}] ({s[left]}) vs s[{right}] ({s[right]})",
    "relationColor": "compared"
  },
  "counters": [
    {
      "name": "comparisons",
      "onLines": [
        10
      ]
    }
  ],
