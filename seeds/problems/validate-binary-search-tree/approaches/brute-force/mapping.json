{
  "primitive": "tree",
  "nodesFrom": "nodes",
  "currentNodeVar": "node_id",
  "nodeStateRules": [
    {
      "state": "error",
      "when": "state_by_id[node_idx] == 3"
    },
    {
      "state": "current",
      "when": "node_idx == node_id"
    },
    {
      "state": "visited",
      "when": "state_by_id[node_idx] == 2"
    },
    {
      "state": "frontier",
      "when": "state_by_id[node_idx] == 1"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "readout": {
    "when": "node_id != null",
    "expr": "at node {node_id}"
  },
  "counters": [
    {
      "name": "nodes validated",
      "onLines": [
        30
      ],
      "when": "true"
    },
    {
      "name": "scan visits",
      "onLines": [
        53,
        65
      ],
      "when": "true"
    }
  ],
  "phaseRules": [
