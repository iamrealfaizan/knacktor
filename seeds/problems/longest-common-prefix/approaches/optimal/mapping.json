{
  "primitive": "array",
  "valuesFrom": "strs",
  "pointers": [
    {
      "name": "i",
      "var": "i"
    }
  ],
  "flags": {},
  "cellStateRules": [
    {
      "state": "current",
      "when": "idx == i"
    },
    {
      "state": "special",
      "when": "idx == 0"
    },
    {
      "state": "visited",
      "when": "idx < i"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "readout": {
    "when": "phase != 'return'",
    "expr": "candidate prefix = {prefix}"
  },
  "counters": [
    {
      "name": "prefix checks",
      "onLines": [
        6,
        9
      ]
    },
    {
      "name": "shrinks",
      "onLines": [
        8
      ]
    }
  ],
  "phaseRules": [
    {
      "phase": "init",
      "lines": [
        3
      ]
    },
    {
      "phase": "loop",
      "lines": [
        4,
        7
      ]
    },
    {
      "phase": "check",
      "lines": [
        5,
        6,
        10
      ]
    },
    {
      "phase": "update",
      "lines": [
        8,
        9,
        11,
        13
      ]
    },
    {
      "phase": "return",
      "lines": [
        12,
        14
      ]
    }
  ],
  "keyEvents": [
    {
      "line": 8,
      "label": "Candidate shrinks",
      "kind": "boundary"
    },
    {
      "line": 12,
      "label": "No common prefix",
      "kind": "return"
    },
    {
      "line": 14,
      "label": "Final prefix returned",
      "kind": "return"
    }
  ]
}
