{
  "primitive": "tree",
  "nodesFrom": "nodes",
  "currentNodeVar": "node_id",
  "nodeStateRules": [
    {
      "state": "current",
      "when": "node_idx == node_id"
    },
    {
      "state": "visited",
      "when": "state_by_id[node_idx] == 2"
    },
    {
      "state": "frontier",
      "when": "state_by_id[node_idx] == 1"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "auxMappings": [
    {
      "label": "preorder (roots in order)",
      "primitive": "array",
      "valuesFrom": "preorder",
      "cellStateRules": [
        {
          "state": "current",
          "when": "idx == node_id"
        },
        {
          "state": "visited",
          "when": "idx < pre_idx[0]"
        },
        {
          "state": "idle",
          "when": "true"
        }
      ]
    },
    {
      "label": "inorder (window splits at root)",
      "primitive": "array",
      "valuesFrom": "inorder",
      "cellStateRules": [
        {
          "state": "current",
          "when": "idx == middle"
        },
        {
          "state": "compared",
          "when": "left <= idx && idx <= right"
        },
        {
          "state": "idle",
          "when": "true"
        }
      ]
    }
  ],
  "readout": {
    "when": "node_id != null",
    "expr": "building subtree over inorder [{left}..{right}]"
  },
  "counters": [
    {
      "name": "nodes built",
      "onLines": [
        26
      ],
      "when": "true"
    }
  ],
