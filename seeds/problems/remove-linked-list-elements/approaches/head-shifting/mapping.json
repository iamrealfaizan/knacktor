{
  "primitive": "linkedList",
  "nodesFrom": "values",
  "linksFrom": "links",
  "changedLinksFrom": "changed_links",
  "pointers": [
    {
      "name": "start",
      "var": "start"
    },
    {
      "name": "current",
      "var": "current"
    },
    {
      "name": "nxt",
      "var": "nxt"
    }
  ],
  "nodeStateRules": [
    {
      "state": "error",
      "when": "removed[node_idx] == 1"
    },
    {
      "state": "current",
      "when": "node_idx == nxt"
    },
    {
      "state": "compared",
      "when": "node_idx == start && phase == 'loop'"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "ghosts": {
    "track": [
      "start",
      "current",
      "nxt"
    ]
  },
  "flags": {},
  "readout": {
    "when": "phase != 'return'",
    "expr": "removing every node with val = {val}"
  },
  "counters": [
    {
      "name": "nodes removed",
      "onLines": [
        9,
        20
      ]
    }
  ],
  "phaseRules": [
    {
      "phase": "init",
      "lines": [
        3,
        4,
        5,
        6,
        7
      ]
    },
    {
      "phase": "loop",
      "lines": [
        8,
        15,
        27
      ]
    },
    {
      "phase": "check",
      "lines": [
        11,
        17
      ]
    },
    {
      "phase": "update",
      "lines": [
        9,
        12,
        16,
        18,
        19,
        20,
        21,
        24,
        25,
        28
      ]
    },
    {
      "phase": "move",
      "lines": [
        10,
        14,
        23,
        26,
        29
      ]
    },
    {
      "phase": "return",
      "lines": [
        13,
        30
      ]
    }
  ],
  "keyEvents": [
    {
      "line": 9,
      "label": "Head node removed",
      "kind": "match"
    },
    {
      "line": 18,
      "label": "Node bypassed",
      "kind": "match"
    },
    {
      "line": 30,
      "label": "Cleaned list returned",
      "kind": "return"
    }
  ]
}
