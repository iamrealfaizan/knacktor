{
  "primitive": "array",
  "valuesFrom": "s",
  "pointers": [
    {
      "name": "pos",
      "var": "pos"
    }
  ],
  "flags": {
    "started": "scan_start != null"
  },
  "cellStateRules": [
    {
      "state": "special",
      "when": "idx == sign_idx"
    },
    {
      "state": "current",
      "when": "idx == pos"
    },
    {
      "state": "dimmed",
      "when": "started && idx < scan_start"
    },
    {
      "state": "visited",
      "when": "idx < pos"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "ghosts": {
    "track": [
      "pos"
    ]
  },
  "readout": {
    "when": "phase != 'return' && phase != 'init'",
    "expr": "reading number: {sign == -1 ? '-' : ''}{res}"
  },
  "counters": [
    {
      "name": "digits read",
      "onLines": [
        28
      ]
    },
    {
      "name": "spaces skipped",
      "onLines": [
        6
      ]
    }
  ],
  "phaseRules": [
    {
      "phase": "init",
      "lines": [
        3,
        4,
        8,
        9,
        17,
        18,
        19
      ]
    },
    {
      "phase": "loop",
      "lines": [
        5,
        20
      ]
    },
    {
      "phase": "move",
      "lines": [
        6,
        13,
        16,
        29
      ]
    },
    {
      "phase": "update",
      "lines": [
        7,
        11,
        12,
        15,
        21,
        24,
        26,
        28,
        30
      ]
    },
    {
      "phase": "check",
      "lines": [
        10,
        14,
        22,
        23
      ]
    },
    {
      "phase": "return",
      "lines": [
        27,
        31
      ]
    }
  ],
  "keyEvents": [
    {
      "line": 12,
      "label": "Sign found",
      "kind": "boundary"
    },
    {
      "line": 15,
      "label": "Sign found",
      "kind": "boundary"
    },
    {
      "line": 24,
      "label": "Overflow — clamped to max",
      "kind": "result"
    },
    {
      "line": 26,
      "label": "Overflow — clamped to min",
      "kind": "result"
    },
    {
      "line": 31,
      "label": "Integer parsed",
      "kind": "return"
    }
  ]
}
