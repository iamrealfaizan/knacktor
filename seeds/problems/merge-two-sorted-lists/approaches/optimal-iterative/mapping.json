{
  "primitive": "custom",
  "componentKey": "merge-two-sorted-lists",
  "customVars": {
    "list1Rem": "l1_rem",
    "list2Rem": "l2_rem",
    "result": "result",
    "spliceSource": "splice_source",
    "spliceVal": "splice_val",
    "phase": "phase"
  },
  "counters": [
    {
      "name": "splices",
      "onLines": [12, 16, 20, 24]
    }
  ],
  "readout": {
    "when": "len(result) > 0",
    "expr": "merged: {len(result)} nodes"
  },
  "phaseRules": [
    { "phase": "init",   "lines": [3, 4, 5, 6, 7] },
    { "phase": "loop",   "lines": [8, 17, 21] },
    { "phase": "check",  "lines": [9] },
    { "phase": "update", "lines": [10, 11, 12, 14, 15, 16, 18, 19, 20, 22, 23, 24] },
    { "phase": "return", "lines": [25] }
  ],
  "keyEvents": [
    { "line": 12, "label": "Splice from list1", "kind": "match" },
    { "line": 16, "label": "Splice from list2", "kind": "match" },
    { "line": 25, "label": "Merge complete",    "kind": "return" }
  ]
}
