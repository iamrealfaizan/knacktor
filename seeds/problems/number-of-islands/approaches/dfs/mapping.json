{
  "primitive": "grid",
  "gridFrom": "grid",
  "cellStateRules": [
    {
      "state": "current",
      "when": "r == cur_r && c == cur_c"
    },
    {
      "state": "visited",
      "when": "state[r][c] == 2"
    },
    {
      "state": "frontier",
      "when": "state[r][c] == 1"
    },
    {
      "state": "dimmed",
      "when": "grid[r][c] == '0'"
    },
    {
      "state": "idle",
      "when": "true"
    }
  ],
  "auxMappings": [
    {
      "label": "Stack (frontier)",
      "primitive": "stack",
      "itemsFrom": "stack",
      "cellStateRules": [
        {
          "state": "frontier",
          "when": "true"
        },
        {
          "state": "idle",
          "when": "true"
        }
      ]
    }
  ],
  "readout": {
    "expr": "islands found: {count}",
    "when": "phase != 'return'"
  },
  "counters": [
    {
      "name": "cells filled",
      "onLines": [
        23
      ],
      "when": "true"
    },
    {
      "name": "cells scanned",
      "onLines": [
        14
      ],
      "when": "true"
    }
  ],
  "phaseRules": [
    {
      "phase": "init",
      "lines": [
        3,
        4,
        5,
        6,
        7,
        8,
        9,
        10,
        11
      ]
    },
    {
      "phase": "loop",
      "lines": [
        12,
        13,
        19,
        24
      ]
    },
    {
      "phase": "check",
      "lines": [
        14,
        27
      ]
    },
    {
      "phase": "update",
      "lines": [
        15,
        16,
        17,
        18,
        23,
        28,
        29
      ]
    },
    {
      "phase": "move",
      "lines": [
        20,
        21,
        22,
        25,
        26,
        30,
        31
      ]
    },
    {
      "phase": "return",
      "lines": [
        32
      ]
    }
  ],
  "keyEvents": [
    {
      "line": 15,
      "label": "New island found",
      "kind": "boundary"
    },
    {
      "line": 32,
      "label": "All islands counted",
      "kind": "return"
    }
  ]
}
